# ============================================================
# Base Sepolia Privy Sandbox
# Replace ALL values below before deploying or handing off.
# ============================================================

# Privy app ID get from https://dashboard.privy.io
# REPLACE THIS when onboarding to a new Privy workspace.
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Faucet wallet private key (server-side only, never exposed to client)
# REPLACE THIS with a funded wallet private key for the new deployment.
PRIVATE_KEY=your_faucet_wallet_private_key_here

# RPC URL for Base Sepolia (any provider: Alchemy, Infura, public, etc.)
# REPLACE THIS with your own RPC endpoint when updating infrastructure.
RPC_URL=https://your-base-sepolia-rpc-url

# ── Anonymous Transfer (Fairycloak relay) ───────────────────────────────────
# Required to enable the Anonymous Transfer mode in the dashboard.
# Contact hello@fairblock.network to get relay access.
# Server-side relay URL (kept secret, used by the proxy route)
FAIRYCLOAK_URL=https://your-fairycloak-relay-url
# Public URL points to the local proxy do not change this
NEXT_PUBLIC_FAIRYCLOAK_URL=https://your-app-domain/api/fairycloak
