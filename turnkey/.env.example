# ============================================================
# Turnkey — Experimental Embedded Wallet Sandbox (Base Sepolia)
# Replace ALL values below before deploying or handing off.
#
# STATUS: Testing is paused — free-tier Turnkey signatures exhausted.
# Once the account is upgraded, copy the new Organization ID and
# Auth Proxy Config ID from the Turnkey dashboard and replace below.
# ============================================================

# Turnkey parent Organization ID
# REPLACE THIS with the new org ID after account upgrade.
NEXT_PUBLIC_ORGANIZATION_ID=your_turnkey_organization_id_here

# Turnkey Auth Proxy Config ID (links the proxy to your org)
# REPLACE THIS with the value from the Turnkey dashboard after upgrade.
NEXT_PUBLIC_AUTH_PROXY_CONFIG_ID=your_turnkey_auth_proxy_config_id_here

# RPC URL for Base Sepolia (any provider: Alchemy, Infura, public, etc.)
# REPLACE THIS with your own RPC endpoint when updating infrastructure.
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://your-base-sepolia-rpc-url

# Faucet wallet private key (server-side only, never exposed to client)
# REPLACE THIS with a funded wallet private key for the new deployment.
PRIVATE_KEY=your_faucet_wallet_private_key_here
